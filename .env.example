# ============================================
# Root Environment Variables (Docker Compose)
# ============================================
# Copy this file to .env and fill in your values.
# Read by docker compose automatically (same dir).
# NEVER commit the actual .env file to git!
# ============================================

# ====== Database ======
POSTGRES_DB=autonews
POSTGRES_USER=autonews_user
POSTGRES_PASSWORD=CHANGE_ME_to_a_secure_password

# ====== Django ======
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ====== AI Engine API Keys ======
GROQ_API_KEY=your-groq-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# ====== Frontend ======
NEXT_PUBLIC_API_URL=http://localhost:8000
NODE_ENV=development

# ====== Optional Secrets ======
# Sentry DSN for error monitoring
# SENTRY_DSN=https://your-sentry-dsn-here

# Google OAuth Client ID
# GOOGLE_CLIENT_ID=your-google-client-id-here
