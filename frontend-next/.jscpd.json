{
  "minLines": 8,
  "minTokens": 50,
  "threshold": 5,
  "reporters": ["console", "json"],
  "output": "reports/jscpd",
  "ignore": [
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/node_modules/**",
    "**/.next/**",
    "**/out/**",
    "**/app/(public)/privacy-policy/**",
    "**/app/(public)/terms/**",
    "**/app/(public)/about/**",
    "**/app/(public)/contact/**"

  ],
  "languages": ["typescript"]
}
